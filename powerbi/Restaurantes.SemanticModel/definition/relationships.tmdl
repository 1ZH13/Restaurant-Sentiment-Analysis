relationship Restaurantes_Reseñas
	fromColumn: Reseñas.RestauranteID
	toColumn: Restaurantes.RestauranteID

relationship Calendario_Reseñas
	fromColumn: Reseñas.Fecha
	toColumn: Calendario.Date

relationship Restaurantes_Aspectos
	fromColumn: Aspectos.RestauranteID
	toColumn: Restaurantes.RestauranteID

relationship Calendario_Aspectos
	fromColumn: Aspectos.Fecha
	toColumn: Calendario.Date

relationship Aspecto_Aspectos
	fromColumn: Aspectos.Aspecto
	toColumn: Aspecto.Aspecto

