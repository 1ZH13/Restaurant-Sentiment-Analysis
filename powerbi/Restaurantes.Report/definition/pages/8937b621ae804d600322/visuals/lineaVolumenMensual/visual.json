                }
              },
              "queryRef": "Calendario.AñoMes",
              "nativeQueryRef": "AñoMes",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Reseñas"
                    }
                  },
                  "Property": "Total reseñas"
                }
              },
              "queryRef": "Reseñas.Total reseñas",
              "nativeQueryRef": "Total reseñas"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Reseñas"
                    }
                  },
                  "Property": "Media móvil 3 meses"
                }
              },
              "queryRef": "Reseñas.Media móvil 3 meses",
              "nativeQueryRef": "Media móvil 3 meses"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
