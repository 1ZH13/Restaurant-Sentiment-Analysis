# Environment Variables Template
# Copy this file to .env and fill in your values

# Google Gemini API Key (for LLM-based sentiment analysis)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini Model
# Ojo: Google retira modelos para claves nuevas sin aviso. gemini-2.0-flash y
# gemini-2.5-flash ya no sirven. Para ver cuales siguen vivos con tu clave:
#     python -m src.llm.modelos_disponibles
GEMINI_MODEL=gemini-3.5-flash

# Ollama (optional - for local LLM inference)
# Install at: https://ollama.ai/
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Scraping settings
REQUEST_DELAY_SECONDS=2.0
MAX_RETRIES=3

# Data paths
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CACHE_DIR=data/cache
